async function saveSCORE(GAMENAME, NICK, SCORE, PASSWORD) {
    console.log("SENDING:", { GAMENAME, NICK, SCORE, PASSWORD });
    
    const params = new URLSearchParams();
    params.append("GAMENAME", GAMENAME);
    params.append("NICK", NICK);
    params.append("SCORE", SCORE);
    params.append("PASSWORD", PASSWORD);

    try {
        const response = await fetch("./server_side/post_score.php", {
            method: "POST",
            headers: { "Content-Type": "application/x-www-form-urlencoded" },
            body: params.toString()
        });

        const rawText = await response.text(); // Get raw text to see errors
        console.log("SERVER RESPONSE RAW >>>", rawText);

        const data = JSON.parse(rawText); 
        console.log("Save Success Object:", data);
    } catch (err) {
        console.error("Wiring Debug Error:", err);
    }
}
async function printreadSCOREs(GAMENAME,NICK,order = "desc", PASSWORD) {
    await fetch("./server_side/read_scores.php", {
        method: "POST",
        headers: {
            "Content-Type": "application/x-www-form-urlencoded"
        },
        body:
            "GAMENAME=" + encodeURIComponent(GAMENAME) +
            "&NICK=" + encodeURIComponent(NICK) +
            "&order=" + encodeURIComponent(order) +
            "&PASSWORD=" + encodeURIComponent(PASSWORD)
    })
    .then(res => res.text())
    .then(async text => {
        console.log("READ RAW >>>", JSON.stringify(text));
        //return JSON.parse(text);
        const originalString = JSON.stringify(text)
        // Removes all double quotes
        const noDoubleQuotes = originalString.replaceAll('"', '');
        // Removes all single quotes
        const noSingleQuotes = noDoubleQuotes.replaceAll("'", "");

        await MORE(noSingleQuotes);
        return;
    })
    //.then(res => res.json())
    .then(data => {
        console.log("DATA >>>", data);   // 👈 ADD THIS LINE
        if (data.status !== "ok") {
            console.error("Error:", data.message);
            return;
        }
        
        let output = "";

        data.data.forEach(entry => {
            output += entry.NICK + " : " + entry.SCORE + "\n";
        });

        console.log(output);
        return output;
        // optional UI output
        // document.getElementById("SCOREs").textContent = output;
    })
    .catch(err => console.error("Error:", err));
}


async function MINESWEEPER() {
    await PRINT("MINESWEEPER (5X5)");

    let N = 5;
    let M_count = 3;
    let E = 0;
    let startTime = Date.now();

    let M = Array.from({ length: N + 1 }, () => Array(N + 1).fill(0));
    let B = Array.from({ length: N + 1 }, () => Array(N + 1).fill(0));

    let placed = 0;
    while (placed < M_count) {
        let R = Math.floor(Math.random() * N) + 1;
        let C = Math.floor(Math.random() * N) + 1;
        if (M[R][C] !== 9) {
            M[R][C] = 9;
            placed++;
        }
    }

    for (let R = 1; R <= N; R++) {
        for (let C = 1; C <= N; C++) {
            if (M[R][C] === 9) continue;
            let count = 0;
            for (let I = -1; I <= 1; I++) {
                for (let J = -1; J <= 1; J++) {
                    if (R + I >= 1 && R + I <= N && C + J >= 1 && C + J <= N) {
                        if (M[R + I][C + J] === 9) count++;
                    }
                }
            }
            M[R][C] = count;
        }
    }

    while (true) {
        await PRINT("");
        await PRINT("   1 2 3 4 5");
        await PRINT("   ---------");
        for (let R = 1; R <= N; R++) {
            let line = R + "| ";
            for (let C = 1; C <= N; C++) {
                if (B[R][C] === 0) {
                    line += "? ";
                } else if (M[R][C] === 9) {
                    line += "* ";
                } else if (M[R][C] === 0) {
                    line += ". ";
                } else {
                    line += M[R][C] + " ";
                }
            }
            await PRINT(line);
        }

        if (E === 1) await endgame();

        let input = await INPUT("ROW,COL (0,0 TO QUIT)");
        let coords = input.split(",");
        let R = parseInt(coords[0]);
        let C = parseInt(coords[1]);

        if (R === 0) {
            await endgame();
            break;
        }

        if (isNaN(R) || R < 1 || R > N || isNaN(C) || C < 1 || C > N) {
            await PRINT("ERR");
            continue;
        }

        if (M[R][C] === 9) {
            await PRINT("BOOM! GAME OVER");
            for (let I = 1; I <= N; I++) {
                for (let J = 1; J <= N; J++) B[I][J] = 1;
            }
            E = 1;
            continue;
        }

        B[R][C] = 1;

        let F;
        do {
            F = 0;
            for (let r = 1; r <= N; r++) {
                for (let c = 1; c <= N; c++) {
                    if (B[r][c] === 1 && M[r][c] === 0) {
                        for (let i = -1; i <= 1; i++) {
                            for (let j = -1; j <= 1; j++) {
                                let nr = r + i, nc = c + j;
                                if (nr >= 1 && nr <= N && nc >= 1 && nc <= N) {
                                    if (B[nr][nc] === 0) {
                                        B[nr][nc] = 1;
                                        F = 1;
                                    }
                                }
                            }
                        }
                    }
                }
            }
        } while (F === 1);

        let W = 0;
        for (let I = 1; I <= N; I++) {
            for (let J = 1; J <= N; J++) {
                if (B[I][J] === 0) W++;
            }
        }
        if (W === M_count) {
            let endTime = Date.now();
            let totalSeconds = Math.floor((endTime - startTime) / 1000);
            await PRINT("YOU WIN!");
            await PRINT("TIME TAKEN: " + totalSeconds + " SECONDS");
            await saveSCORE("Minesweeper", NICK, totalSeconds.toString(), PASSWORD);
            E = 1;
        }
    }
}

async function endgame() {
    await PRINT("Survivors, time to clear seconds:");
    await printreadSCOREs("Minesweeper", NICK, "ASC", PASSWORD);
    await PRINT("****** PRESS ENTER ******");
    await INPUT();
    // IMPORTANT: stop THIS loop before loading main menu
    quit = true;
    main_menu = await CURL("https://amjp.psy-k.org/JPLY_BBS/utf8-art/JPLY_BBS/proxy.php?url=https://amjp.psy-k.org/JPLY_BBS/scripts/main_menu.JS_BASIC");
    await LOAD(main_menu);
}
MINESWEEPER();
